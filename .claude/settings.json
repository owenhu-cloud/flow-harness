{
  "hooks": {
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.flow/kernel/router.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.flow/kernel/loop-controller.sh" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.flow/kernel/checkpoint.sh" } ] }
    ],
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.flow/kernel/restore.sh" } ] }
    ]
  }
}
